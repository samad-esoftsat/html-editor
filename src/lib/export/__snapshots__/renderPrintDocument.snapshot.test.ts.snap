exports[`renderPrintDocument snapshot parity > Newsletter print template 1`] = `
"<!doctype html>
<html lang="en">
<head>
  <title>Print preview</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
@page {
  size: A4 portrait;
  margin: 18mm 14mm;
}

* { box-sizing: border-box; }
body { margin: 0; padding: 0; }
main { width: 100%; }
main > section { break-inside: avoid; }
body {
  background: #ffffff;
  color: #1c1c1c;
  font-family: Arial, Helvetica Neue, Helvetica, sans-serif;
  font-size: 16px;
}
  </style>
</head>
<body>
  
