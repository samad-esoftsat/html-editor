:710px"><div data-craft-row="true" style="display:flex;flex-direction:row-reverse;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 50%;flex-direction:column;gap:12px;min-width:0"></div><div data-craft-column="true" style="display:flex;flex:0 0 50%;flex-direction:column;gap:12px;min-width:0"><h2 style="color:#1c1c1c;font-size:22px;margin:0 0 8px;text-align:left">Session two</h2><ul style="color:#1c1c1c;font-size:16px;margin:0 0 12px;padding-left:20px;text-align:left"><li>Speaker name</li><li>Topic summary</li><li>Time</li></ul><div style="width:100%;text-align:left"><a href="" rel="noreferrer" style="background-color:#f1592a;border-radius:4px;color:#ffffff;display:inline-block;padding:10px 18px;text-decoration:none" target="_blank">Add to calendar</a></div></div></div></div></section><section data-craft-section="true" style="padding:16px 16px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 50%;flex-direction:column;gap:12px;min-width:0"></div><div data-craft-column="true" style="display:flex;flex:0 0 50%;flex-direction:column;gap:12px;min-width:0"><h2 style="color:#1c1c1c;font-size:22px;margin:0 0 8px;text-align:left">Session three</h2><ul style="color:#1c1c1c;font-size:16px;margin:0 0 12px;padding-left:20px;text-align:left"><li>Speaker name</li><li>Topic summary</li><li>Time</li></ul><div style="width:100%;text-align:left"><a href="" rel="noreferrer" style="background-color:#f1592a;border-radius:4px;color:#ffffff;display:inline-block;padding:10px 18px;text-decoration:none" target="_blank">Add to calendar</a></div></div></div></div></section><section data-craft-section="true" style="padding:32px 24px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-