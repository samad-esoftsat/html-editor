  background: #ffffff;
  color: #1c1c1c;
  font-family: Arial, Helvetica Neue, Helvetica, sans-serif;
  font-size: 16px;
}
  </style>
</head>
<body>
  
  <main><div data-craft-page="true" style="background:#ffffff;color:#1c1c1c;font-family:Arial, Helvetica Neue, Helvetica, sans-serif;min-height:100%"><section data-craft-section="true" style="padding:16px 16px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:12px;min-width:0"></div></div><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:12px;min-width:0"><h3 style="color:#1c1c1c;font-size:18px;margin:0 0 8px;text-align:center">Big news</h3></div></div><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:12px;min-width:0"></div></div><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:12px;min-width:0"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:center"></h2></div></div></div></section><section data-craft-section="true" style="padding:40px 24px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:12px;min-width:0"><h1 style="color:#1c1c1c;font-size:28px;margin:0 0 8px;text-align:center">We&#x27;re launching something new</h1><p style="color:#1c1c1c;font-size:16px;margin:0 0 8px;text-align:center;white-space:pre-wrap">A short, punchy sentence about why this matters.</p><div style="width:100%;text-align:center"><a href="" rel="noreferrer" style="background-color:#f1592a;border-radius:4px;color:#ffffff;display:inline-block;padding:10px 18px;text-decoration:none" target="_blank">Get the details</a></div></div></div></div></section><section data-craft-section="true" style="padding:24px 24px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 40%;flex-direction:column;gap:12px;min-width:0"></div><div data-craft-column="true" style="display:flex;flex:0 0 60%;flex-direction:column;gap:12px;min-width:0"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:left">Why this matters</h2><p style="color:#1c1c1c;font-size:16px;margin:0 0 8px;text-align:left;white-space:pre-wrap">A few sentences of supporting context. Lead with the customer benefit; explain the mechanism second.</p><div style="width:100%;text-align:left"><a href="" rel="noreferrer" style="background-color:#f1592a;border-radius:4px;color:#ffffff;display:inline-block;padding:10px 18px;text-decoration:none" target="_blank">Read the post</a></div></div></div></div></section><section data-craft-section="true" style="padding:32px 24px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:12px;min-width:0"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:center">Ready to try it?</h2><p style="color:#1c1c1c;margin:0 0 8px;text-align:center;white-space:pre-wrap"></p><div style="width:100%;text-align:center"><a href="" rel="noreferrer" style="background-color:#f1592a;border-radius:4px;color:#ffffff;display:inline-block;padding:10px 18px;text-decoration:none" target="_blank">Get started</a></div></div></div></div></section><section data-craft-section="true" style="background-color:#000000;padding:16px 16px"><div style="margin:0 auto;max-width:710px"><div data-craft-row="true" style="display:flex;flex-direction:row;gap:16px;width:100%"><div data-craft-column="true" style="display:flex;flex:0 0 100%;flex-direction:column;gap:4px;min-width:0"></div></div></div></section></div></main>
</body>
</html>"
`;

