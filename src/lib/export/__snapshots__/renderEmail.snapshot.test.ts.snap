exports[`renderEmail snapshot parity > Newsletter template 1`] = `
"<!DOCTYPE html>
<html xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office" lang="en">
<head>
<title></title>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="x-apple-disable-message-reformatting">
<meta name="format-detection" content="telephone=no, date=no, address=no, email=no">
<style>
  * { box-sizing: border-box; }
  body { margin: 0; padding: 0; }
  a[x-apple-data-detectors] { color: inherit !important; text-decoration: inherit !important; }
  p { line-height: inherit; }
  img { max-width: 100%; height: auto; }
</style>
</head>
<body style="margin: 0; padding: 0; background-color: #ffffff; font-family: Arial, Helvetica Neue, Helvetica, sans-serif; font-size: 16px;">
<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="background-color: #ffffff;">
  <tr>
    <td align="center">
      <table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:16px 16px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h3 style="color:#1c1c1c;font-size:18px;margin:0 0 8px;text-align:center">Monthly update</h3></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:center">What we shipped this month</h2></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:40px 24px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h1 style="color:#1c1c1c;font-size:28px;margin:0 0 8px;text-align:center">This month at our company</h1><p style="color:#1c1c1c;font-size:16px;margin:0 0 8px;text-align:center;white-space:pre-wrap">A short note from the team - the highlights, in one place.</p><table role="presentation" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto"><tbody><tr><td style="background-color:#f1592a;border-radius:4px;padding:10px 18px;text-align:center"><a href="" style="color:#ffffff;display:inline-block;font-weight:600;text-decoration:none" target="_blank" rel="noreferrer">See the full update</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:24px 24px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:left">Story one</h2><p style="color:#1c1c1c;font-size:16px;margin:0 0 8px;text-align:left;white-space:pre-wrap">A short paragraph or two about the first story. Keep it under five lines.</p><table role="presentation" border="0" cellPadding="0" cellSpacing="0" style="margin:0"><tbody><tr><td style="background-color:#f1592a;border-radius:4px;padding:10px 18px;text-align:left"><a href="" style="color:#ffffff;display:inline-block;font-weight:600;text-decoration:none" target="_blank" rel="noreferrer">Read more</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:24px 24px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:left">Story two</h2><p style="color:#1c1c1c;font-size:16px;margin:0 0 8px;text-align:left;white-space:pre-wrap">Another short paragraph. Newsletter readers skim - short beats long.</p><table role="presentation" border="0" cellPadding="0" cellSpacing="0" style="margin:0"><tbody><tr><td style="background-color:#f1592a;border-radius:4px;padding:10px 18px;text-align:left"><a href="" style="color:#ffffff;display:inline-block;font-weight:600;text-decoration:none" target="_blank" rel="noreferrer">Read more</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:24px 24px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:left">Story three</h2><p style="color:#1c1c1c;font-size:16px;margin:0 0 8px;text-align:left;white-space:pre-wrap">Wrap up with a third item that nudges readers toward the next step.</p><table role="presentation" border="0" cellPadding="0" cellSpacing="0" style="margin:0"><tbody><tr><td style="background-color:#f1592a;border-radius:4px;padding:10px 18px;text-align:left"><a href="" style="color:#ffffff;display:inline-block;font-weight:600;text-decoration:none" target="_blank" rel="noreferrer">Read more</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:32px 24px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"><h2 style="color:#1c1c1c;font-size:25px;margin:0 0 8px;text-align:center">Want more?</h2><p style="color:#1c1c1c;margin:0 0 8px;text-align:center;white-space:pre-wrap">Get future editions straight to your inbox.</p><table role="presentation" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto"><tbody><tr><td style="background-color:#f1592a;border-radius:4px;padding:10px 18px;text-align:center"><a href="" style="color:#ffffff;display:inline-block;font-weight:600;text-decoration:none" target="_blank" rel="noreferrer">Subscribe -&gt;</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="background-color:#000000"><tbody><tr><td><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0" style="margin:0 auto;max-width:710px;width:100%"><tbody><tr><td style="padding:16px 16px"><table role="presentation" width="100%" border="0" cellPadding="0" cellSpacing="0"><tbody><tr><td width="100%" valign="top" style="padding:0;width:100%"></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table>
    </td>
  </tr>
</table>
</body>
</html>"
`;
